{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build CPBL",
            "type": "shell",
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/d", "/c"]
                }
            },
            "command": "gcc",
            "args": [
                "db.c",
                "auth.c",
                "board.c",
                "mypage.c",
                "main.c",
                "Admin_Interface.c",
                "-o",
                "CPBL.exe",
                "-I",
                "C:\\Program Files\\MySQL\\MySQL Server 8.0\\include",
                "C:\\Program Files\\MySQL\\MySQL Server 8.0\\lib\\libmysql.lib"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Compiler: gcc"
        }
    ]
}
